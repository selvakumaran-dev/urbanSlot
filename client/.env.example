# Vite client environment (copy to .env.local and fill in real values)
# .env.local is gitignored — never commit real secrets

# Backend API base URL (leave empty for local dev — Vite proxy handles it)
# For production (e.g. Render, Railway), set this to your deployed backend:
# VITE_API_URL=https://your-backend.onrender.com
VITE_API_URL=
