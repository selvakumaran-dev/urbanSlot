# UrbanSlot Server — Environment Variables
# DO NOT commit this file. Copy it to .env and fill in your real values.

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas — replace with your actual connection string
# 1. Go to https://cloud.mongodb.com
# 2. Create a free M0 cluster
# 3. Click "Connect" > "Drivers" > copy the connection string
# 4. Replace <username> and <password> with your Atlas username and password
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/urbanslot?retryWrites=true&w=majority

# JWT — change this to a long random string in production
JWT_SECRET=replace_with_a_long_random_secret_string_here
JWT_EXPIRES_IN=7d

# Frontend origin (for CORS) — set to your deployed frontend URL in production
# Local dev: http://localhost:5173
# Production: https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# Stripe (optional — for payment processing)
STRIPE_SECRET_KEY=sk_test_replace_this
